# Private operator artifacts — strategy/marketing drafts NEVER pushed to remote.
# The entire plans/ tree is local-only by policy: drafts, strategy notes, pricing,
# distribution plans, paper-working artifacts, research scratch, autoresearch outputs.
# If a plans/* file is genuinely publish-shaped (e.g. prior-art research), MOVE it
# to docs/ — do NOT exception it back into git from plans/.
plans/

# Per-project audit outputs — operator strategy + cross-project findings, not toolkit deliverables
audits/

# install.sh sync backups of pre-existing local skill files (auto-generated)
*.personal-backup

# P2 real-trace data — contains operator/project context; NEVER commit (local only)
eval/p2_real_verdicts.jsonl
eval/p2_rejudge_fullpayload.jsonl
eval/real_traces*.jsonl

# startup-intel: Obsidian mirror vault is a local-only derived view (may hold operator strategy)
intel-vault/

# never track a local X/xAI token file
.x_bearer_token
*bearer*token*
